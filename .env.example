# Supabase project URL. Use the base project URL, not the REST URL.
# Correct: https://your-project-ref.supabase.co
# Incorrect: https://your-project-ref.supabase.co/rest/v1/
VITE_SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase publishable key (sb_publishable_...). Do not use a secret/service role key in the browser.
VITE_SUPABASE_ANON_KEY=sb_publishable_your_publishable_key
